PORT=5000
DB_HOST=localhost
DB_PORT=3306
DB_NAME=be_btvn
DB_USER=root
DB_PASSWORD=your-password

JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
JWT_REFRESH_EXPIRE=7d

# Email Configuration (Gmail SMTP)
# To use Gmail, you need to:
# 1. Enable 2-factor authentication on your Gmail account
# 2. Generate an "App Password" at: https://myaccount.google.com/apppasswords
# 3. Use the app password (not your regular Gmail password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM_NAME=BE_BTVN

# MoMo Payment (sandbox)
# Default sandbox test credentials are already filled; replace with your merchant keys for production.
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=F8BBA842ECF85
MOMO_SECRET_KEY=K951B6PE1waDMi640xX08PD3vg6EkVlz
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
# Public URL (ngrok) that MoMo can POST IPN to. Must be HTTPS when running with real MoMo.
MOMO_IPN_URL=https://your-public-host.ngrok.io/api/v1/payments/momo/ipn
# URL MoMo redirects the user to after payment — can be a deep link for the mobile app.
MOMO_REDIRECT_URL=https://your-public-host.ngrok.io/api/v1/payments/momo/return
MOMO_REQUEST_TYPE=captureWallet
