# Optional overrides for docker-compose.
# Copy to `.env` (same folder as docker-compose.yml) and edit values you care about.
# Only MoMo URLs usually need changing — everything else has sensible defaults.

# Public URL (ngrok / cloudflared) that MoMo can POST IPN to.
MOMO_IPN_URL=https://your-public-host.ngrok-free.app/api/v1/payments/momo/ipn
MOMO_REDIRECT_URL=https://your-public-host.ngrok-free.app/api/v1/payments/momo/return
